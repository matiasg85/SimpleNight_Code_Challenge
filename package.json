{
  "name": "simplenight-fw",
  "version": "1.0.0",
  "description": "Playwright + TypeScript test-automation framework for Simplenight",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:hotels": "playwright test tests/hotels/",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:staging": "cross-env TEST_ENV=staging playwright test",
    "test:production": "cross-env TEST_ENV=production playwright test",
    "report": "playwright show-report",
    "allure:serve": "allure serve allure-results",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "typescript": "^5.5.0"
  }
}
